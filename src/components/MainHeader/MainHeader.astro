---
const { Home = false } = Astro.props;
import SITE_INFO from "@/config";
import "./MainHeader.less";
---

<div class:list={["header-main", Home && "home-hero"]}>
	{
		Home ? (
			<>
				<div class="hero-copy">
					<span class="eyebrow">个人主页</span>
					<h1 class="auther">{SITE_INFO.Author || "-"}</h1>
					<p class="intro">
						我是韩小韩，持续记录前端工程、边缘部署、AI 应用和自托管实践。
					</p>
					<div class="hero-actions">
						<a class="hero-action primary" href="/blog">查看文章目录</a>
						<a class="hero-action secondary" href="/resume">CV / 个人简历</a>
					</div>
					<p class="desc"></p>
				</div>
				<div class="avatar">
					<img src="/assets/images/lazy-loading.webp" data-vh-lz-src={SITE_INFO.Avatar} alt="avatar" />
				</div>
			</>
		) : (
			<>
				<div class="avatar">
					<img src="/assets/images/lazy-loading.webp" data-vh-lz-src={SITE_INFO.Avatar} alt="avatar" />
				</div>
				<h3 class="auther">{SITE_INFO.Author || "-"}</h3>
				<p class="desc"></p>
			</>
		)
	}
</div>
