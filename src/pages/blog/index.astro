---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout/Layout.astro";
import SITE_CONFIG from "@/config";
import BLOG_FOLDERS from "@/page_data/BlogFolders";
import { fmtTime, getDescription } from "@/utils/index";
import "@/styles/BlogDirectory.less";

const visiblePosts = (await getCollection("blog"))
  .filter((post) => !post.data.hide)
  .sort((a, b) => {
    if (Boolean(a.data.top) !== Boolean(b.data.top)) {
      return Number(Boolean(b.data.top)) - Number(Boolean(a.data.top));
    }
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

const folderMap = new Map(
  BLOG_FOLDERS.map((folder) => [folder.slug, { ...folder, posts: [] as typeof visiblePosts }]),
);

for (const post of visiblePosts) {
  const targetFolder = folderMap.get(post.data.folder);
  if (!targetFolder) {
    throw new Error(`Unknown blog folder "${post.data.folder}" for article "${post.data.id}"`);
  }
  targetFolder.posts.push(post);
}

const folders = [...folderMap.values()].sort((a, b) => a.order - b.order);
const defaultFolder = folders[0];
---

<Layout title="文章目录" description={SITE_CONFIG.Description} activeNav="blog">
	<section class="blog-directory vh-animation vh-animation-init" data-default-folder={defaultFolder.slug}>
		<aside class="blog-directory-sidebar">
			<div class="blog-directory-heading">
				<span>文章目录</span>
				<h1>按逻辑文件夹浏览</h1>
				<p>从不同主题入口快速找到我写过的文章与项目记录。</p>
			</div>
			<nav class="blog-folder-list">
				{
					folders.map((folder, index) => (
						<a
							class={`blog-folder-link${index === 0 ? " active" : ""}`}
							href={`/blog?folder=${folder.slug}`}
							data-folder-link={folder.slug}
						>
							<strong>{folder.name}</strong>
							<span>{folder.posts.length} 篇文章</span>
						</a>
					))
				}
			</nav>
		</aside>

		<section class="blog-directory-content">
			{
				folders.map((folder, index) => (
					<section
						class={`blog-folder-panel${index === 0 ? " active" : ""}`}
						data-folder-panel={folder.slug}
						hidden={index !== 0}
					>
						<header class="blog-folder-header">
							<span>文件夹</span>
							<h2>{folder.name}</h2>
							<p>{folder.description}</p>
						</header>

						<div class="blog-folder-posts">
							{
								folder.posts.length ? (
									folder.posts.map((post) => (
										<article class="blog-post-card">
											<div class="blog-post-meta">
												<time>{fmtTime(post.data.date, "YYYY-MM-DD")}</time>
												{post.data.top && <span class="top-flag">置顶</span>}
											</div>
											<h3>
												<a href={`/article/${post.data.id}`}>{post.data.title}</a>
											</h3>
											<p>{post.data.summary || getDescription(post, 96)}</p>
											{
												(post.data.tags || []).length > 0 && (
													<div class="blog-post-tags">
														{(post.data.tags || []).map((tag) => <a href={`/tag/${tag}`}>#{tag}</a>)}
													</div>
												)
											}
										</article>
									))
								) : (
									<div class="blog-folder-empty">
										<p>这个文件夹还没有文章，后面我会继续补充。</p>
									</div>
								)
							}
						</div>
					</section>
				))
			}
		</section>
	</section>

	<script is:inline>
		const root = document.querySelector(".blog-directory");
		if (root) {
			const folderPanels = [...root.querySelectorAll("[data-folder-panel]")];
			const folderLinks = [...root.querySelectorAll("[data-folder-link]")];
			const defaultFolder = root.getAttribute("data-default-folder") || "";
			const searchParams = new URLSearchParams(window.location.search);
			const requestedFolder = searchParams.get("folder") || defaultFolder;
			const validFolder = folderPanels.some((panel) => panel.getAttribute("data-folder-panel") === requestedFolder)
				? requestedFolder
				: defaultFolder;

			folderPanels.forEach((panel) => {
				const active = panel.getAttribute("data-folder-panel") === validFolder;
				panel.toggleAttribute("hidden", !active);
				panel.classList.toggle("active", active);
			});

			folderLinks.forEach((link) => {
				const active = link.getAttribute("data-folder-link") === validFolder;
				link.classList.toggle("active", active);
			});
		}
	</script>
</Layout>
