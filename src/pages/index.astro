---
import SITE_CONFIG from "@/config";
import Layout from "@/layouts/Layout/Layout.astro";
import "@/styles/Home.less";

const featuredSites = [
  { title: "查看文章目录", href: "/blog", desc: "按逻辑文件夹浏览全部文章与项目记录。" },
  { title: "CV / 个人简历", href: "/resume", desc: "查看我的经历、技能栈和代表项目。" },
  { title: "昔日归档", href: "/archives", desc: "按时间线回看我写过的内容。" },
];

const directions = [
  { title: "前端工程", desc: "围绕 Astro、Vue 和现代构建工具打磨内容体验。" },
  { title: "边缘部署", desc: "关注 Cloudflare、全球分发与高可用部署方案。" },
  { title: "AI 应用", desc: "把大模型能力接进分析、自动化和日常工作流。" },
  { title: "自托管", desc: "持续折腾 Homelab、容器服务和家庭网络。" },
];

const projects = [
  { title: "Blog", href: "/", desc: "记录技术实践、迁移经验和长期折腾的主阵地。" },
  { title: "Han Analytics", href: "https://analytics.vvhan.com", desc: "自建访问分析服务，持续验证边缘托管方案。" },
  { title: "Cloudflare 优选", href: "https://cf.vvhan.com", desc: "围绕优选 IP 与访问质量优化的在线工具。" },
];
---

<Layout title="" description={SITE_CONFIG.Description} Home={true}>
	<section class="home-page vh-animation vh-animation-init">
		<section class="home-section home-intro">
			<div class="home-section-title">
				<span>个人主页</span>
				<h2>你好，我是 Zheng Han</h2>
			</div>
			<p>
				这里不再只是文章首页，而是我介绍自己、整理方向、承接项目与输出内容的个人入口。
			</p>
			<p>
				如果你想快速了解我，可以先看简历；如果你想系统浏览内容，可以直接进入文章目录。
			</p>
		</section>

		<section class="home-section">
			<div class="home-section-title">
				<span>技术方向</span>
				<h2>我长期关注的几条主线</h2>
			</div>
			<div class="home-grid">
				{directions.map((item) => (
					<article class="home-card">
						<h3>{item.title}</h3>
						<p>{item.desc}</p>
					</article>
				))}
			</div>
		</section>

		<section class="home-section">
			<div class="home-section-title">
				<span>入口导航</span>
				<h2>从这里继续往下看</h2>
			</div>
			<div class="home-grid">
				{featuredSites.map((item) => (
					<a class="home-card home-link-card" href={item.href}>
						<h3>{item.title}</h3>
						<p>{item.desc}</p>
					</a>
				))}
			</div>
		</section>

		<section class="home-section">
			<div class="home-section-title">
				<span>项目与站点</span>
				<h2>我在持续维护的一些东西</h2>
			</div>
			<div class="home-grid">
				{projects.map((item) => (
					<a class="home-card home-link-card" href={item.href} target={item.href.startsWith("http") ? "_blank" : "_self"} rel="noopener noreferrer">
						<h3>{item.title}</h3>
						<p>{item.desc}</p>
					</a>
				))}
			</div>
		</section>
	</section>
</Layout>
