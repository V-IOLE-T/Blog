      "ignore": ["dist/**", "**/*.css.ts"],
      "vite": false
    }
  },
  "ignore": ["haklex/rich-editor-demo/**"],
  "ignoreDependencies": [
    "@vanilla-extract/css",
    "@vanilla-extract/recipes",
